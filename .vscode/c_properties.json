{
    "configurations": [
        {
            "name": "OSDev",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/kernel/limine-protocol/include",
                "${workspaceFolder}/kernel/freestnd-c-hdrs/include",
                "${workspaceFolder}/kernel/libc/include",
                "${workspaceFolder}/kernel/src"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/x86_64-elf-gcc",
